    {
      "name": "Happy Path - Customer Onboarding",
      "item": [
        {
          "name": "Register new customer",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// 1. Define Polish first and last names categorized by gender\r",
                  "const maleFirstNames = [\"Jan\", \"Piotr\", \"Krzysztof\", \"Andrzej\", \"Tomasz\", \"Michał\", \"Marcin\", \"Jakub\", \"Adam\", \"Łukasz\"];\r",
                  "const femaleFirstNames = [\"Anna\", \"Maria\", \"Katarzyna\", \"Małgorzata\", \"Agnieszka\", \"Krystyna\", \"Barbara\", \"Ewa\", \"Elżbieta\", \"Magdalena\"];\r",
                  "\r",
                  "const maleLastNames = [\"Kowalski\", \"Nowak\", \"Wiśniewski\", \"Wójcik\", \"Kowalczyk\", \"Kamiński\", \"Lewandowski\", \"Zieliński\", \"Szymański\", \"Woźniak\"];\r",
                  "const femaleLastNames = [\"Kowalska\", \"Nowak\", \"Wiśniowiecka\", \"Wójcik\", \"Kowalczyk\", \"Kamińska\", \"Lewandowska\", \"Zielińska\", \"Szymańska\", \"Woźniak\"];\r",
                  "\r",
                  "// 2. Randomly assign gender (0 = female, 1 = male)\r",
                  "const isMale = Math.floor(Math.random() * 2);\r",
                  "\r",
                  "// 3. Select randomized first and last name based on gender\r",
                  "const firstName = isMale\r",
                  "    ? maleFirstNames[Math.floor(Math.random() * maleFirstNames.length)]\r",
                  "    : femaleFirstNames[Math.floor(Math.random() * femaleFirstNames.length)];\r",
                  "\r",
                  "const lastName = isMale\r",
                  "    ? maleLastNames[Math.floor(Math.random() * maleLastNames.length)]\r",
                  "    : femaleLastNames[Math.floor(Math.random() * femaleLastNames.length)];\r",
                  "\r",
                  "// 4. Generate email address and normalize Polish characters\r",
                  "const cleanText = (text) =>\r",
                  "    text\r",
                  "        .toLowerCase()\r",
                  "        .normalize(\"NFD\")\r",
                  "        .replace(/[\\u0300-\\u036f]/g, \"\")\r",
                  "        .replace(/ł/g, \"l\");\r",
                  "\r",
                  "const email = `${cleanText(firstName)}.${cleanText(lastName)}@example-bank.pl`;\r",
                  "\r",
                  "// 5. Store generated customer data as Postman environment variables\r",
                  "pm.environment.set(\"random_first_name\", firstName);\r",
                  "pm.environment.set(\"random_last_name\", lastName);\r",
                  "pm.environment.set(\"random_email\", email);\r",
                  "pm.environment.set(\r",
                  "    \"random_password\",\r",
                  "    Math.random().toString(36).substring(2, 10) + \"A1!\"\r",
                  ");\r",
                  "\r",
                  "// 6. Generate a valid PESEL number with checksum validation\r",
                  "function generatePesel(isMaleGender) {\r",
                  "\r",
                  "    // Generate randomized birth date (1950–2005)\r",
                  "    const year = Math.floor(Math.random() * (2005 - 1950 + 1)) + 1950;\r",
                  "    const month = Math.floor(Math.random() * 12) + 1;\r",
                  "    const day = Math.floor(Math.random() * 28) + 1; // Simplified to max 28 days\r",
                  "\r",
                  "    let yy = year.toString().slice(-2);\r",
                  "    let mm = month < 10 ? \"0\" + month : month.toString();\r",
                  "    let dd = day < 10 ? \"0\" + day : day.toString();\r",
                  "\r",
                  "    // Adjust month encoding for people born after year 2000\r",
                  "    if (year >= 2000) {\r",
                  "        mm = (parseInt(mm) + 20).toString();\r",
                  "    }\r",
                  "\r",
                  "    // Generate random serial digits\r",
                  "    const serial = Math.floor(100 + Math.random() * 900).toString();\r",
                  "\r",
                  "    // Gender digit:\r",
                  "    // odd = male\r",
                  "    // even = female\r",
                  "    const genderDigits = isMaleGender\r",
                  "        ? [1, 3, 5, 7, 9]\r",
                  "        : [0, 2, 4, 6, 8];\r",
                  "\r",
                  "    const genderDigit =\r",
                  "        genderDigits[Math.floor(Math.random() * genderDigits.length)].toString();\r",
                  "\r",
                  "    const peselWithoutControl = yy + mm + dd + serial + genderDigit;\r",
                  "\r",
                  "    // Calculate PESEL control digit using official weights\r",
                  "    const weights = [1, 3, 7, 9, 1, 3, 7, 9, 1, 3];\r",
                  "\r",
                  "    let sum = 0;\r",
                  "\r",
                  "    for (let i = 0; i < 10; i++) {\r",
                  "        sum += parseInt(peselWithoutControl[i]) * weights[i];\r",
                  "    }\r",
                  "\r",
                  "    const controlDigit = (10 - (sum % 10)) % 10;\r",
                  "\r",
                  "    return peselWithoutControl + controlDigit.toString();\r",
                  "}\r",
                  "\r",
                  "// 7. Generate and store PESEL number in Postman environment\r",
                  "const generatedPesel = generatePesel(isMale);\r",
                  "\r",
                  "pm.environment.set(\"generated_pesel\", generatedPesel);\r",
                  "\r",
                  "// Optional: Display generated test data in Postman console for debugging purposes\r",
                  "console.log(\r",
                  "    `Generated customer: ${firstName} ${lastName}, Male: ${!!isMale}, Email: ${email}, PESEL: ${generatedPesel}`\r",
                  ");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Should return 201 Created when customer is registered\",  () => {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "const responseData = pm.response.json();\r",
                  "\r",
                  "const email = responseData.email;\r",
                  "const password = responseData.password;\r",
                  "const userId = responseData.id;\r",
                  "\r",
                  "pm.environment.set(\"registered_email\", email);\r",
                  "pm.environment.set(\"registered_password\", password);\r",
                  "pm.environment.set(\"customer_id\", userId);\r",
                  "\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"firstName\": \"{{random_first_name}}\",\r\n  \"lastName\": \"{{random_last_name}}\",\r\n  \"email\": \"{{random_email}}\",\r\n  \"pesel\": \"{{generated_pesel}}\",\r\n  \"password\": \"{{random_password}}\"\r\n}\r\n",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/customers",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "customers"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Log in customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Should return 200 OK when customer is logged in\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Should successfully extract token from response\", () => {\r",
                  "    const responseData = pm.response.json();\r",
                  "    const token = responseData.token;\r",
                  "    \r",
                  "    pm.expect(token).to.not.be.undefined; \r",
                  "    pm.environment.set(\"token\", token);\r",
                  "});\r",
                  "\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
