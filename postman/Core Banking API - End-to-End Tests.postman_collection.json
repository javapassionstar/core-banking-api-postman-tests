        {
          "name": "Log in customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Should return 200 OK when customer is logged in\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Should successfully extract token from response\", () => {\r",
                  "    const responseData = pm.response.json();\r",
                  "    const token = responseData.token;\r",
                  "    \r",
                  "    pm.expect(token).to.not.be.undefined; \r",
                  "    pm.environment.set(\"token\", token);\r",
                  "});\r",
                  "\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
