                  "pm.test(\"Should return correct error object structure\", () => {\r",
                  "    const responseData = pm.response.json();\r",
                  "    pm.expect(responseData.error).to.eql(\"Unauthorized\");\r",
                  "    pm.expect(responseData.message).to.eql(\"Brak autoryzacji. Wymagany poprawny token Bearer.\");\r",
